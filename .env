LLM_PROVIDER=lmstudio
LLM_BASE_URL=http://localhost:1234/v1
LLM_API_KEY=lm-studio
LLM_MODEL=qwen3.5-0.8b

# STT (Speech-to-Text) — used only with lmstudio provider
STT_MODEL=base

# VAD (Voice Activity Detection) — listens until you stop speaking
VAD_MODE=true
VAD_SILENCE_TIMEOUT=1.5
VAD_THRESHOLD=0.02

# Wake word detection: true | false
# When true, assistant only responds when you say: Jarvis / Джарвис / Жарвис
WAKE_MODE=true
WAKE_WORDS=jarvis,джарвис,жарвис

# Input mode: vad | key
#   vad = voice activity detection (stops when you pause)
#   key = press Enter to start, VAD to stop
# Only used when WAKE_MODE=false
INPUT_MODE=vad

# TTS Backend: edge | yandex | macos | print
TTS_BACKEND=edge

# TTS Voice:
#   edge:    ru-RU-SvetlanaNeural | ru-RU-DariyaNeural | ru-RU-DmitryNeural | en-US-JennyNeural | en-US-GuyNeural
#   yandex:  alisa | filipp | oksana | zahar | ermil
#   macos:   any installed system voice (run `say -v '?'` to list)
TTS_VOICE=ru-RU-DmitryNeural
TTS_LANG=ru-RU

# Yandex SpeechKit (only needed if TTS_BACKEND=yandex)
# Get API key at https://console.cloud.yandex.com
YC_API_KEY=
YC_FOLDER_ID=

DEBUG=True
