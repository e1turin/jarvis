# ── Agent identity ────────────────────────────────────────
# AGENT_NAME        — used in console title and "AgentName: text" prefix
# WAKE_WORD_DISPLAY — shown in "Say '...' to wake me up" messages.
#                     If empty, uses first WAKE_WORDS word (capitalized).
AGENT_NAME=Jarvis
WAKE_WORD_DISPLAY=Джарвис


# ── Wake word detection (Vosk) ────────────────────────────
# Wake word is detected offline by Vosk. Multiple words can be
# comma-separated: старина,стрина. They must be lowercase.
WAKE_MODE=true
WAKE_WORDS=джарвис
VOSK_MODEL_PATH=vosk-model-small-ru-0.22


# ── LLM (OpenAI-compatible API) ──────────────────────────
# Point to any OpenAI-compatible server:
#   LM Studio:  http://localhost:1234/v1
#   Ollama:     http://localhost:11434/v1
LLM_BASE_URL=http://localhost:1234/v1
LLM_API_KEY=lm-studio
LLM_MODEL=google/gemma-4-12b-qat
# LLM_TEMPERATURE=0.7    # 0.0–1.0 (higher = more creative)
# LLM_MAX_TOKENS=1024


# ── Speech-to-Text (faster-whisper) ──────────────────────
# Model size: tiny, base, small, medium, large, large-v3
# Larger = more accurate but slower and more RAM.
# STT_MODEL=base


# ── Voice Activity Detection ─────────────────────────────
# VAD_MODE=true        # true = listen until silence, false = fixed 5s
# VAD_SILENCE_TIMEOUT=1.5   # seconds of silence before stopping
# VAD_THRESHOLD=0.02        # lower = more sensitive to quiet speech


# ── Text-to-Speech ───────────────────────────────────────
# Backend        Quality     Internet   Platform
# ─────────────  ─────────── ────────── ──────────────────
# say (macOS)    ★★★ Good    ❌ Offline  Built-in (recommended)
# edge           ★★★★ Best   ⚠️ Needed   Cross-platform
# espeak         ★★ Robotic  ❌ Offline  Cross-platform (install espeak-ng)
# print          —           ❌ Offline  No audio (debug only)
# yandex         ★★★★ Best   ⚠️ Needed   Yandex Cloud API key required
TTS_BACKEND=say
TTS_VOICE=Milena
# TTS_RATE=+0%   # +20% faster, -20% slower


# ── Conversation timeout ─────────────────────────────────
# After this many seconds of silence, returns to wake-word listening.
# CONVERSATION_TIMEOUT=30


# ── Sound feedback (beep / ticks) ────────────────────────
# LISTEN_BEEP_FREQ=200     # Hz (lower = deeper)
# LISTEN_BEEP_DURATION=0.2 # seconds
# LISTEN_BEEP_VOLUME=0.4   # 0.0–1.0
# TICK_FREQ=350            # thinking tick pitch (Hz)
# TICK_DURATION=0.03       # thinking tick length
# TICK_VOLUME=0.15
# TICK_INTERVAL=2.0        # seconds between ticks
# TICK_VIBRO=false         # use system beep instead of audio (may trigger haptic)


# ── System prompt ────────────────────────────────────────
# Path to the system prompt text file.
# Supports __AGENT_NAME__ and __WAKE_WORD__ placeholders.
# Default: src/jarvis/prompt.txt
# SYSTEM_PROMPT_PATH=src/jarvis/prompt.txt


# ── Yandex TTS (only if TTS_BACKEND=yandex) ─────────────
# YC_API_KEY=...
# YC_FOLDER_ID=...
# TTS_VOICE=alisa
# TTS_LANG=ru-RU
