# =============================================================================
# Jarvis Voice AI Assistant — Configuration
# =============================================================================
# Copy this file to .env and customize for your setup:
#   cp .env.example .env

# ---------------------------------------------------------------------------
# LLM Provider (LM Studio or OpenAI-compatible API)
# ---------------------------------------------------------------------------
LLM_PROVIDER=lmstudio          # "lmstudio" or "openai"
LLM_BASE_URL=http://localhost:1234/v1
LLM_API_KEY=lm-studio          # LM Studio accepts any non-empty key
LLM_MODEL=google/gemma-4-12b-qat  # Model loaded in LM Studio

# ---------------------------------------------------------------------------
# Speech-to-Text (STT)
# ---------------------------------------------------------------------------
STT_MODEL=base                 # faster-whisper model size: tiny, base, small, medium, large

# ---------------------------------------------------------------------------
# Voice Activity Detection (VAD)
# ---------------------------------------------------------------------------
VAD_MODE=true                  # true = listen with VAD, false = fixed duration
VAD_SILENCE_TIMEOUT=1.5        # seconds of silence before stopping recording
VAD_THRESHOLD=0.02             # energy threshold (lower = more sensitive)

# ---------------------------------------------------------------------------
# Text-to-Speech (TTS)
# ---------------------------------------------------------------------------
TTS_BACKEND=edge               # "edge" (Microsoft Edge TTS), "yandex", or "print" (no audio)
TTS_VOICE=ru-RU-DmitryNeural   # Edge TTS voice name. Alternative: ru-RU-DmitryNeural
# For Yandex SpeechKit (only if TTS_BACKEND=yandex):
# YC_API_KEY=...
# YC_FOLDER_ID=...
# TTS_VOICE=alisa
# TTS_LANG=ru-RU

# ---------------------------------------------------------------------------
# Wake Word Detection
# ---------------------------------------------------------------------------
WAKE_MODE=true                 # true = wait for wake word, false = always listening
WAKE_WORDS=джарвис             # comma-separated list of wake words (lowercase)
VOSK_MODEL_PATH=vosk-model-small-ru-0.22  # Path to Vosk model directory

# ---------------------------------------------------------------------------
# Sound Feedback
# ---------------------------------------------------------------------------
TICK_VIBRO=false               # true = use system beep (may trigger haptic on Force Touch Macs)
LISTEN_BEEP_FREQ=200           # listening beep frequency in Hz
LISTEN_BEEP_DURATION=0.2       # listening beep duration in seconds
LISTEN_BEEP_VOLUME=0.4         # listening beep volume (0.0–1.0)
TICK_FREQ=350                  # thinking tick frequency in Hz
TICK_DURATION=0.03             # thinking tick duration in seconds
TICK_VOLUME=0.15               # thinking tick volume (0.0–1.0)
TICK_INTERVAL=3.0              # seconds between thinking ticks

# ---------------------------------------------------------------------------
# System Prompt
# ---------------------------------------------------------------------------
# Path to a text file with the system prompt. Default: src/jarvis/prompt.txt
# SYSTEM_PROMPT_PATH=custom_prompt.txt

# ---------------------------------------------------------------------------
# Conversation
# ---------------------------------------------------------------------------
CONVERSATION_TIMEOUT=30        # seconds of inactivity before auto-sleep
