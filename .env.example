# ──────────────────────────────────────────────────────────
# Jarvis Voice AI Assistant — Configuration
# ──────────────────────────────────────────────────────────
# Copy this file to .env and edit it:
#   cp .env.example .env
# ──────────────────────────────────────────────────────────

# --- LLM (OpenAI-compatible API) ---
# For LM Studio: http://localhost:1234/v1
# For Ollama (local): http://localhost:11434/v1
LLM_PROVIDER=lmstudio
LLM_BASE_URL=http://localhost:1234/v1
LLM_API_KEY=lm-studio
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=google/gemma-4-12b-qat
# LLM_MODEL=gemma3:12b

LLM_MODEL=google/gemma-4-12b-qat
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1024

# --- STT (faster-whisper) ---
# Model size: tiny, base, small, medium, large, large-v3
STT_MODEL=base

# --- VAD (Voice Activity Detection) ---
VAD_MODE=true
VAD_SILENCE_TIMEOUT=1.5
VAD_THRESHOLD=0.02

# --- TTS (Text-to-Speech) ---
# ┌──────────────┬──────────────────────────────────────────────┐
# │ Backend      │ Description                                  │
# ├──────────────┼──────────────────────────────────────────────┤
# │ edge         │ Microsoft Edge TTS (requires internet)       │
# │ say          │ macOS built-in (fully offline, recommended)  │
# │ espeak       │ espeak-ng (cross-platform, offline, robotic) │
# │ yandex       │ Yandex SpeechKit (requires internet + keys)  │
# │ print        │ No audio — print response only (debug)       │
# └──────────────┴──────────────────────────────────────────────┘
TTS_BACKEND=say
# ── Edge TTS voices ─────────────────────────────────
# TTS_VOICE=ru-RU-SvetlanaNeural
# TTS_VOICE=ru-RU-DariyaNeural
# TTS_VOICE=ru-RU-DmitryNeural
# ── macOS `say` voices ──────────────────────────────
# Run `say -v '?' | grep ru` to list installed Russian voices
TTS_VOICE=Milena
# ── espeak-ng voices ────────────────────────────────
# Run `espeak-ng --voices | grep ru` to list Russian voices
# TTS_VOICE=ru
# ── Speech rate ─────────────────────────────────────
# Format: +0% (default), +20% (faster), -20% (slower)
# For `say` backend: +0% ≈ 200 wpm
TTS_RATE=+0%

# --- Yandex SpeechKit (only if TTS_BACKEND=yandex) ---
# YC_API_KEY=
# YC_FOLDER_ID=
# TTS_VOICE=alisa
# TTS_LANG=ru-RU

# --- Wake word (Vosk) ---
WAKE_MODE=true
WAKE_WORDS=джарвис
VOSK_MODEL_PATH=vosk-model-small-ru-0.22

# --- Conversation ---
CONVERSATION_TIMEOUT=30

# --- Sound feedback ---
TICK_VIBRO=false
LISTEN_BEEP_FREQ=200
LISTEN_BEEP_DURATION=0.2
LISTEN_BEEP_VOLUME=0.4
TICK_FREQ=350
TICK_DURATION=0.03
TICK_VOLUME=0.15
TICK_INTERVAL=2.0

# --- System prompt ---
# Path to the system prompt text file (editable at runtime)
# Default: src/jarvis/prompt.txt
# SYSTEM_PROMPT_PATH=src/jarvis/prompt.txt
