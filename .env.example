# ┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓
# ┃  🟢  SIMPLE SETTINGS  —  start here                        ┃
# ┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛

# ── Section 1: Identity ────────────────────────────────────────
# AGENT_NAME        Name shown in console: "--- Name ---", "Name: text"
# WAKE_WORD_DISPLAY How the wake word is displayed in UI
# WAKE_WORDS        Comma-separated wake words (lowercase) that trigger/interrupt
#                    Example: "джарвис,жарвис,старина"
AGENT_NAME=Jarvis
WAKE_WORD_DISPLAY=Джарвис
WAKE_WORDS=джарвис

# ── Section 2: LLM (OpenAI-compatible API) ─────────────────────
# LLM_BASE_URL      API base URL
#                     LM Studio:  http://localhost:1234/v1
#                     Ollama:     http://localhost:11434/v1
#                     OpenAI:     https://api.openai.com/v1
#                     Gemini:     https://generativelanguage.googleapis.com/v1beta/openai
# LLM_API_KEY       API key (leave empty for LM Studio)
# LLM_MODEL         Model name
# LLM_TEMPERATURE   Response creativity (0.0–1.0)
# LLM_MAX_TOKENS    Max tokens per response
# LLM_TIMEOUT       HTTP client timeout (seconds)
# LLM_MAX_RETRIES   Max API retries on failure
LLM_BASE_URL=http://localhost:1234/v1
LLM_API_KEY=
LLM_MODEL=google/gemma-4-12b-qat
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1024
LLM_TIMEOUT=30
LLM_MAX_RETRIES=1

# ── Section 3: Text-to-Speech ──────────────────────────────────
# TTS_BACKEND       Backend: edge, say, espeak, yandex, or print
# TTS_VOICE         Voice name
#                     say:    Milena (macOS built-in Russian)
#                     edge:   ru-RU-SvetlanaNeural
#                     espeak: ru
#                     yandex: alisa, filipp, etc.
# TTS_RATE          Speech rate: +0% normal, +20% faster, -20% slower
# TTS_VOLUME        Playback volume (0.0–1.0, macOS afplay only)
# TTS_GEN_TIMEOUT   TTS generation timeout (seconds)
TTS_BACKEND=edge
TTS_VOICE=ru-RU-SvetlanaNeural
TTS_RATE=+0%
TTS_VOLUME=1.0
TTS_GEN_TIMEOUT=60

# ── Section 4: Conversation ────────────────────────────────────
# CONVERSATION_TIMEOUT  Inactivity timeout (seconds) before going back to sleep
# SLEEP_WORDS           Comma-separated words/phrases to end conversation
CONVERSATION_TIMEOUT=30
SLEEP_WORDS=пока,до свидания,всё,свободен,bye,goodbye,спать,иди спать,отдыхай,закончили,хватит


# ┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓
# ┃  🟠  ADVANCED SETTINGS  —  tweak only if needed             ┃
# ┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛

# ── Section 5: Wake Word Detection (Vosk) ──────────────────────
# WAKE_MODE              Enable wake word detection (false = always listening)
# VOSK_MODEL_PATH        Path to Vosk model directory
# PRE_WAKE_BUFFER_SECONDS Seconds of rolling audio kept before wake word
WAKE_MODE=true
VOSK_MODEL_PATH=vosk-model-small-ru-0.22
PRE_WAKE_BUFFER_SECONDS=3.0

# ── Section 6: Voice Activity Detection ────────────────────────
# VAD_MODE           Enable VAD (false = record fixed duration)
# VAD_SILENCE_TIMEOUT Seconds of silence before recording stops
# VAD_THRESHOLD      Energy threshold (lower = more sensitive)
# VAD_BLOCK_SIZE_MS  VAD analysis window (milliseconds)
# LISTENER_MAX_WAIT  Max seconds to wait for initial speech before giving up
VAD_MODE=true
VAD_SILENCE_TIMEOUT=1.5
VAD_THRESHOLD=0.02
VAD_BLOCK_SIZE_MS=50
LISTENER_MAX_WAIT=10

# ── Section 7: Speech-to-Text (faster-whisper) ─────────────────
# STT_MODEL        Model size: tiny, base, small, medium, large-v3
# STT_DEVICE       Device: cpu or cuda
# STT_COMPUTE_TYPE Compute type: int8, float16, float32
STT_MODEL=base
STT_DEVICE=cpu
STT_COMPUTE_TYPE=int8

# ── Section 8: Audio / Microphone ───────────────────────────────
# AUDIO_SAMPLE_RATE  Sample rate for microphone capture (Hz)
AUDIO_SAMPLE_RATE=16000

# ── Section 9: Sound Feedback (beep / ticks) ────────────────────
# TICK_VIBRO           Use system beep for tick (may trigger haptic on Macs)
# LISTEN_BEEP_FREQ     Listening beep frequency (Hz)
# LISTEN_BEEP_DURATION Listening beep duration (seconds)
# LISTEN_BEEP_VOLUME   Listening beep volume (0.0–1.0)
# TICK_FREQ            Thinking tick frequency (Hz)
# TICK_DURATION        Thinking tick duration (seconds)
# TICK_VOLUME          Thinking tick volume (0.0–1.0)
# TICK_INTERVAL        Interval between thinking ticks (seconds)
# SOUNDS_SAMPLE_RATE   Sample rate for beep/tick WAV generation (Hz)
TICK_VIBRO=false
LISTEN_BEEP_FREQ=200
LISTEN_BEEP_DURATION=0.2
LISTEN_BEEP_VOLUME=0.4
TICK_FREQ=350
TICK_DURATION=0.03
TICK_VOLUME=0.15
TICK_INTERVAL=2.0
SOUNDS_SAMPLE_RATE=22050

# ── Section 10: Proxy (HTTP / HTTPS / SOCKS5) ───────────────────
# HTTP_PROXY    HTTP proxy URL (e.g. http://host:port)
# HTTPS_PROXY   HTTPS or SOCKS5 proxy URL (e.g. socks5://host:1080)
# NO_PROXY      Comma-separated hosts to bypass proxy
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,::1

# ── Section 11: MCP (Model Context Protocol) ────────────────────
# Web search is BUILT-IN via DuckDuckGo (free, no config needed).
# You DON'T need to set MCP_SERVERS for web search.
#
# MCP_SERVERS is only for adding CUSTOM tools from external servers.
# Format: JSON array of command/args objects
# Example: [{"command":"npx","args":["-y","some-mcp-server"]}]
MCP_SERVERS=

# ── Section 12: System Prompt ───────────────────────────────────
# SYSTEM_PROMPT_PATH  Path to system prompt text file
SYSTEM_PROMPT_PATH=src/jarvis/prompt.txt

# ── Section 13: Yandex TTS (requires cloud API key) ─────────────
# YC_API_KEY    Yandex Cloud API key for SpeechKit
# YC_FOLDER_ID  Yandex Cloud folder ID
# TTS_LANG      TTS language code
YC_API_KEY=
YC_FOLDER_ID=
TTS_LANG=ru-RU

# ── Section 14: Temporary Files ─────────────────────────────────
# TEMP_DIR  Directory for temporary audio files
TEMP_DIR=.
